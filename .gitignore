# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Claude Code (ignore user settings, keep hooks and project settings)
.claude/*
!.claude/hooks/
!.claude/settings.json

# Dashboard build output
.loci/dashboard/data.json

# ─── Personal data (stays local after onboarding) ───
# install.sh auto-disconnects from the template remote,
# so your data never gets pushed to the public repo.
# If you use your own private remote, all files are safe to track.
.loci/status.yml
.loci/activity-log.md
.loci/last-consolidation.txt
# NOTE: The .loci/config settings file is intentionally tracked (NOT ignored).
# It contains persistence/routing/privacy settings that should be version-controlled
# so your brain configuration is portable and restorable. No secrets are stored there.
