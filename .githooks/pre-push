#!/bin/bash
# Loci: Prevent accidental push to template repo
# Protects personal data from being pushed to the public repository

remote="$1"
url="$2"

# Only block if brain has personal data (plan.md status: active)
# Template status = no personal data yet = safe to push
SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
if [[ "$url" == *"codesstar/loci"* ]] && grep -q "status: active" "$SCRIPT_DIR/plan.md" 2>/dev/null; then
  echo ""
  echo "⚠️  BLOCKED: You're pushing to the public Loci template repo."
  echo "   Your brain contains personal data — this would make it public."
  echo ""
  echo "   To back up your brain, push to a PRIVATE repo instead:"
  echo "   git remote set-url origin git@github.com:YOUR_USER/my-brain.git"
  echo ""
  exit 1
fi
